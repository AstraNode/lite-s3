# Uploads Directory Security
# Temporary storage for multipart uploads - NO DIRECT ACCESS

# Deny all direct access (Apache 2.4+)
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

# Deny all direct access (Apache 2.2)
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>

# Block script files from execution
<FilesMatch "\.(php|phtml|php3|php4|php5|php7|phps|phar|inc|pl|cgi|sh|py|exe|bat|cmd)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Disable script execution
Options -ExecCGI -Includes -Indexes
RemoveHandler .php .phtml .php3 .php4 .php5 .php7 .phps .phar .pl .cgi .sh .py

# Disable PHP engine completely
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php8.c>
    php_flag engine off
</IfModule>
