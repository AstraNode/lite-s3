# Logs Directory Security
# Prevent access to log files

# Deny all direct access (Apache 2.4+)
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

# Deny all direct access (Apache 2.2)
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>

# Disable directory listing
Options -Indexes

# Disable script execution
Options -ExecCGI
RemoveHandler .php .phtml .php3 .php4 .php5 .php7 .phps .phar

# Disable PHP engine
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php8.c>
    php_flag engine off
</IfModule>
