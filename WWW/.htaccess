# S3 Object Storage - Apache Configuration
# Compatible with LAMP, XAMPP, and shared hosting (cPanel/Plesk)

# Enable rewrite engine
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Pass Authorization header to PHP (required for Apache CGI/FastCGI)
    # Method 1: Environment variable
    SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1
    
    # Method 2: Rewrite rule (backup)
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
    
    # Route all requests to index.php (except actual files)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Remove server info
    Header unset Server
    Header unset X-Powered-By
    
    # CORS headers for S3 API compatibility
    Header always set Access-Control-Allow-Origin "*"
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, HEAD, OPTIONS, COPY"
    Header always set Access-Control-Allow-Headers "Authorization, Content-Type, x-amz-date, x-amz-content-sha256, x-amz-user-agent, x-amz-target, x-amz-copy-source, x-amz-acl, x-amz-meta-*, Range, If-Match, If-None-Match, If-Modified-Since"
    Header always set Access-Control-Expose-Headers "ETag, x-amz-request-id, x-amz-id-2, Content-Length, Last-Modified, x-amz-version-id"
    Header always set Access-Control-Max-Age "86400"
</IfModule>

# PHP settings for shared hosting (mod_php)
<IfModule mod_php.c>
    php_value upload_max_filesize 5G
    php_value post_max_size 5G
    php_value max_execution_time 43200
    php_value max_input_time 43200
    php_value memory_limit 512M
    php_flag display_errors off
    php_flag log_errors on
</IfModule>

# PHP settings for PHP 7+ (mod_php7/8)
<IfModule mod_php7.c>
    php_value upload_max_filesize 5G
    php_value post_max_size 5G
    php_value max_execution_time 43200
    php_value max_input_time 43200
    php_value memory_limit 512M
</IfModule>

<IfModule mod_php8.c>
    php_value upload_max_filesize 5G
    php_value post_max_size 5G
    php_value max_execution_time 43200
    php_value max_input_time 43200
    php_value memory_limit 512M
</IfModule>

# Disable directory listing
Options -Indexes

# Default charset
AddDefaultCharset UTF-8

# Deny access to sensitive files
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

<FilesMatch "(config\.php|\.env|composer\.(json|lock)|\.installed)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

<FilesMatch "\.log$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Enable compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE application/xml application/json text/plain text/html text/css application/javascript
</IfModule>